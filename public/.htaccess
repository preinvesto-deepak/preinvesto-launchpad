<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing FILES normally
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Serve existing DIRECTORIES normally EXCEPT "/portfolio" (SPA route)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !^/portfolio/?$
  RewriteRule ^ - [L]

  # Everything else goes to index.html (client-side routing)
  RewriteRule . /index.html [L]
</IfModule>

# Fallback: if hosting returns 403/404 on deep links, route to SPA
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html
